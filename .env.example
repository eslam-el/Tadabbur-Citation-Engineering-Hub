# قاعدة البيانات (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# المصادقة (Auth.js v5)
AUTH_SECRET="ولّده بـ: npx auth secret"
AUTH_URL="http://localhost:3000"   # في الإنتاج: https://<vercel-domain>

# Google OAuth (من Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# المدير الجذري (بريد جوجل — يُمنح ADMIN+ACTIVE دائمًا)
ADMIN_EMAIL="you@example.com"
